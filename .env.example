TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=replace_me
TELEGRAM_SESSION_NAME=main_account
TELEGRAM_SESSION_DIR=./data/sessions
PRIMARY_MENTION=@unsigned69
MESSAGE_LIMIT=30
MEMORY_TTL_SECONDS=600
GROUP_REPLY_COUNTER_THRESHOLD=100
